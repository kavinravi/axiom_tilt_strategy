# Copy to ib-gateway.env and fill in. Use the DEDICATED VPS username (see deploy/README.md),
# not your dad's main login — a competing login breaks the auto-restart session.
TWS_USERID=your_dedicated_vps_username
TWS_PASSWORD=your_password

# paper first; switch to live only after a clean supervised run.
TRADING_MODE=paper

# Auto-restart (NOT auto-logoff) => 2FA only once/week after the Sunday 01:00 ET reset.
# Daily soft restart time, account local time:
TWS_SETTINGS_PATH=/home/ibgateway/Jts
IBC_AUTO_RESTART_TIME=11:59 PM
# On a 2FA timeout, restart and retry the login rather than exiting:
TWOFA_TIMEOUT_ACTION=restart
AUTO_RESTART_TIME=11:59 PM

# Keep order placement enabled (this is a trading bot):
READ_ONLY_API=no

TZ=America/New_York
