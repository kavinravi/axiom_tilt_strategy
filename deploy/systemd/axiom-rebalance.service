[Unit]
Description=Axiom Tilt - Monday rebalance toward the frozen weights
OnFailure=axiom-alert@%n.service

[Service]
Type=oneshot
WorkingDirectory=%h/axiom_tilt_strategy
# SAFE DEFAULT: paper. Change to "--mode live" ONLY after a clean supervised live run.
# No --confirm: this runs unattended. asof defaults to the most recent Friday.
ExecStart=%h/axiom_tilt_strategy/.venv/bin/python -m trading.run rebalance --mode paper
