[Unit]
Description=Axiom Tilt - intraday dashboard tick (broker NAV + holdings P&L, 15-min)
# No OnFailure: the tick self-skips outside market hours / when the Gateway is
# briefly unreachable, and a hard outage pages via the 16:30 EOD publish instead
# of 26 duplicate alerts a day.

[Service]
Type=oneshot
WorkingDirectory=%h/axiom_tilt_strategy
ExecStart=%h/axiom_tilt_strategy/.venv/bin/python -m trading.publish --intraday
