[Unit]
Description=Axiom Tilt - publish live snapshot to the dashboard
OnFailure=axiom-alert@%n.service

[Service]
Type=oneshot
WorkingDirectory=%h/axiom_tilt_strategy
# trading.publish self-guards US market hours and no-ops (no Gateway connect) off-hours.
ExecStart=%h/axiom_tilt_strategy/.venv/bin/python -m trading.publish
