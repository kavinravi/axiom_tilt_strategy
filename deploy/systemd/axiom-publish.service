[Unit]
Description=Axiom Tilt - EOD dashboard publish (broker NetLiquidation truth)
OnFailure=axiom-alert@%n.service

[Service]
Type=oneshot
WorkingDirectory=%h/axiom_tilt_strategy
# Broker account channel: NAV = NetLiquidation, holdings P&L via reqPnLSingle.
# Stamps the official daily equity point at 16:30. Hard failure -> alert.
ExecStart=%h/axiom_tilt_strategy/.venv/bin/python -m trading.publish
